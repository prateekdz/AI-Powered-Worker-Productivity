# Copy this file to `.env.local` and edit values for your environment
# Note: Vite requires all client-side env vars to start with VITE_

# Backend API URL (where the Express server is running)
# Local development:
#   VITE_BACKEND_URL=http://localhost:3001
# Production with Render backend:
#   VITE_BACKEND_URL=https://your-backend-service.onrender.com
# Example:
#   VITE_BACKEND_URL=https://ai-worker-backend.onrender.com

VITE_BACKEND_URL=http://localhost:3001
